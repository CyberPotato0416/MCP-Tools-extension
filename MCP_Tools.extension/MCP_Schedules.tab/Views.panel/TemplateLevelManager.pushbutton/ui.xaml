<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="樣板樓層管理工具" Width="420" SizeToContent="Height"
        ShowInTaskbar="False" WindowStartupLocation="CenterScreen" Background="#F5F5F5">
    <Border Padding="15">
        <StackPanel>
            <TextBlock Text="視圖樣板動態白名單管理" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="#333333"/>

            <TabControl x:Name="MainTabControl" Background="White" BorderBrush="#CCCCCC">
                <!-- TAB 1 -->
                <TabItem Header=" 樣板 A ">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="Tab1_Enabled" Content="啟用此樣板過濾" Margin="0,5,0,10" FontWeight="Bold"/>
                        <Label Content="選擇視圖樣板:" FontSize="11" Foreground="#666666" Padding="0,0,0,2"/>
                        <ComboBox x:Name="Tab1_TemplateCombo" DisplayMemberPath="Name" Height="26" Margin="0,0,0,10" BorderBrush="#CCCCCC"/>
                        <Label Content="保留顯示樓層 (白名單):" FontSize="11" Foreground="#666666" Padding="0,0,0,2"/>
                        <ListBox x:Name="Tab1_LevelList" Height="180" BorderBrush="#CCCCCC" Background="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </TabItem>
                <!-- TAB 2 -->
                <TabItem Header=" 樣板 B ">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="Tab2_Enabled" Content="啟用此樣板過濾" Margin="0,5,0,10" FontWeight="Bold"/>
                        <Label Content="選擇視圖樣板:" FontSize="11" Foreground="#666666" Padding="0,0,0,2"/>
                        <ComboBox x:Name="Tab2_TemplateCombo" DisplayMemberPath="Name" Height="26" Margin="0,0,0,10" BorderBrush="#CCCCCC"/>
                        <Label Content="保留顯示樓層 (白名單):" FontSize="11" Foreground="#666666" Padding="0,0,0,2"/>
                        <ListBox x:Name="Tab2_LevelList" Height="180" BorderBrush="#CCCCCC" Background="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </TabItem>
                <!-- TAB 3 -->
                <TabItem Header=" 樣板 C ">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="Tab3_Enabled" Content="啟用此樣板過濾" Margin="0,5,0,10" FontWeight="Bold"/>
                        <Label Content="選擇視圖樣板:" FontSize="11" Foreground="#666666" Padding="0,0,0,2"/>
                        <ComboBox x:Name="Tab3_TemplateCombo" DisplayMemberPath="Name" Height="26" Margin="0,0,0,10" BorderBrush="#CCCCCC"/>
                        <Label Content="保留顯示樓層 (白名單):" FontSize="11" Foreground="#666666" Padding="0,0,0,2"/>
                        <ListBox x:Name="Tab3_LevelList" Height="180" BorderBrush="#CCCCCC" Background="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="儲存並執行更新" Width="140" Height="32" Click="OnSaveAndApply"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"/>
                <Button Content="取消" Width="70" Height="32" Margin="8,0,0,0" Click="OnCancel"
                        BorderBrush="#CCCCCC" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
